<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="myDUWorkbench.Views.ExportJsonDialog"
        Title="Export JSON"
        Width="900"
        Height="700"
        MinWidth="640"
        MinHeight="420"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12"
          RowDefinitions="*,Auto"
          RowSpacing="10">
        <TextBox x:Name="JsonTextBox"
                 Grid.Row="0"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Stretch" />

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
            <TextBlock x:Name="ActionResultText"
                       VerticalAlignment="Center"
                       Foreground="DarkSeaGreen"
                       Text="" />
            <Button Content="Save to..."
                    Click="OnSaveToClick" />
            <Button Content="Copy"
                    Click="OnCopyClick" />
            <Button Content="Close"
                    Click="OnCloseClick" />
        </StackPanel>
    </Grid>
</Window>

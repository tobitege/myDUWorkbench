<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="myDUWorkbench.Views.VoxelAnalysisDialog"
        Title="Voxel Analysis"
        Width="1320"
        Height="860"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12"
          RowDefinitions="Auto,Auto,*,Auto"
          RowSpacing="10">
        <Border Grid.Row="0"
                BorderThickness="1"
                BorderBrush="#505050"
                CornerRadius="4"
                Padding="8">
            <TextBlock x:Name="OverviewTextBlock"
                       TextWrapping="Wrap"
                       Text="No analysis data." />
        </Border>

        <Border Grid.Row="1"
                BorderThickness="1"
                BorderBrush="#505050"
                CornerRadius="4"
                Padding="8">
            <Grid RowDefinitions="Auto,*"
                  RowSpacing="4">
                <TextBlock Grid.Row="0"
                           FontWeight="SemiBold"
                           Text="Potential Errors" />
                <TextBox Grid.Row="1"
                         x:Name="PotentialErrorsTextBox"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="72"
                         MaxHeight="120"
                         ScrollViewer.VerticalScrollBarVisibility="Auto" />
            </Grid>
        </Border>

        <DataGrid Grid.Row="2"
                  x:Name="BlobInstancesGrid"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="True"
                  CanUserResizeColumns="True"
                  MinColumnWidth="10"
                  GridLinesVisibility="Horizontal"
                  IsReadOnly="True"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  UseLogicalScrollable="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="#"
                                    Binding="{Binding RowNumber}"
                                    Width="70"
                                    MinWidth="10"
                                    x:CompileBindings="False" />
                <DataGridTextColumn Header="Cell"
                                    Binding="{Binding CellIndex}"
                                    Width="80"
                                    MinWidth="10"
                                    x:CompileBindings="False" />
                <DataGridTextColumn Header="Coords"
                                    Binding="{Binding Coords}"
                                    Width="130"
                                    MinWidth="10"
                                    x:CompileBindings="False" />
                <DataGridTextColumn Header="h"
                                    Binding="{Binding H}"
                                    Width="55"
                                    MinWidth="10"
                                    x:CompileBindings="False" />
                <DataGridTextColumn Header="Blob"
                                    Binding="{Binding Blob}"
                                    Width="120"
                                    MinWidth="10"
                                    x:CompileBindings="False" />
                <DataGridTextColumn Header="Status"
                                    Binding="{Binding Status}"
                                    Width="160"
                                    MinWidth="10"
                                    x:CompileBindings="False" />
                <DataGridTextColumn Header="Vertices"
                                    Binding="{Binding VertexSamples}"
                                    Width="100"
                                    MinWidth="10"
                                    x:CompileBindings="False" />
                <DataGridTextColumn Header="Voxels"
                                    Binding="{Binding VoxelBlocks}"
                                    Width="100"
                                    MinWidth="10"
                                    x:CompileBindings="False" />
                <DataGridTextColumn Header="Mat Runs"
                                    Binding="{Binding MaterialRuns}"
                                    Width="90"
                                    MinWidth="10"
                                    x:CompileBindings="False" />
                <DataGridTextColumn Header="Vert Runs"
                                    Binding="{Binding VertexRuns}"
                                    Width="90"
                                    MinWidth="10"
                                    x:CompileBindings="False" />
                <DataGridTextColumn Header="Raw B"
                                    Binding="{Binding RawBytes}"
                                    Width="100"
                                    MinWidth="10"
                                    x:CompileBindings="False" />
                <DataGridTextColumn Header="Decoded B"
                                    Binding="{Binding DecodedBytes}"
                                    Width="110"
                                    MinWidth="10"
                                    x:CompileBindings="False" />
                <DataGridTextColumn Header="Mat Tokens"
                                    Binding="{Binding MaterialTokens}"
                                    Width="260"
                                    MinWidth="10"
                                    IsVisible="False"
                                    x:CompileBindings="False" />
                <DataGridTextColumn Header="Materials (DB)"
                                    Binding="{Binding MaterialNames}"
                                    Width="360"
                                    MinWidth="10"
                                    x:CompileBindings="False" />
                <DataGridTextColumn Header="Details / Error"
                                    Binding="{Binding Error}"
                                    Width="420"
                                    MinWidth="10"
                                    x:CompileBindings="False" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
            <TextBlock x:Name="ActionResultTextBlock"
                       VerticalAlignment="Center"
                       Foreground="DarkSeaGreen"
                       Text="" />
            <Button Content="Save JSON..."
                    Click="OnSaveToClick" />
            <Button Content="Copy JSON"
                    Click="OnCopyClick" />
            <Button Content="Close"
                    Click="OnCloseClick" />
        </StackPanel>
    </Grid>
</Window>

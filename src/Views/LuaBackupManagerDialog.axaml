<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="myDUWorkbench.Views.LuaBackupManagerDialog"
        Title="LUA Backups"
        Width="1280"
        Height="840"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12"
          RowDefinitions="Auto,3*,Auto,2*,2*,Auto"
          RowSpacing="10">
        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto,Auto,Auto"
              ColumnSpacing="8">
            <TextBlock Grid.Column="0"
                       x:Name="BackupLocationText"
                       VerticalAlignment="Center"
                       Text="Backup folder:" />
            <Button Grid.Column="1"
                    Content="Refresh"
                    Click="OnRefreshClick" />
            <Button Grid.Column="2"
                    Content="Delete selected"
                    Click="OnDeleteSelectedClick" />
            <Button Grid.Column="3"
                    Content="Delete all"
                    Click="OnDeleteAllClick" />
        </Grid>

        <DataGrid Grid.Row="1"
                  x:Name="BackupsGrid"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="True"
                  CanUserResizeColumns="True"
                  GridLinesVisibility="Horizontal"
                  UseLogicalScrollable="True"
                  SelectionChanged="OnBackupsSelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Backup UTC"
                                    Binding="{Binding BackupUtc}"
                                    x:CompileBindings="False"
                                    Width="190"
                                    MinWidth="150" />
                <DataGridTextColumn Header="ElementId"
                                    Binding="{Binding ElementId}"
                                    x:CompileBindings="False"
                                    Width="110"
                                    MinWidth="90" />
                <DataGridTextColumn Header="Element"
                                    Binding="{Binding ElementDisplayName}"
                                    x:CompileBindings="False"
                                    Width="2*"
                                    MinWidth="160" />
                <DataGridTextColumn Header="Node"
                                    Binding="{Binding NodeLabel}"
                                    x:CompileBindings="False"
                                    Width="2*"
                                    MinWidth="160" />
                <DataGridTextColumn Header="Property"
                                    Binding="{Binding PropertyName}"
                                    x:CompileBindings="False"
                                    Width="140"
                                    MinWidth="110" />
                <DataGridTextColumn Header="Preview"
                                    Binding="{Binding Preview}"
                                    x:CompileBindings="False"
                                    Width="3*"
                                    MinWidth="220" />
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2"
                Padding="10"
                BorderBrush="#3A3A3A"
                BorderThickness="1"
                CornerRadius="4">
            <TextBlock x:Name="ComparisonSummaryText"
                       Text="Select a backup to compare."
                       TextWrapping="Wrap" />
        </Border>

        <Grid Grid.Row="3"
              ColumnDefinitions="*,*"
              ColumnSpacing="10">
            <Grid Grid.Column="0"
                  RowDefinitions="Auto,*"
                  RowSpacing="6">
                <TextBlock Grid.Row="0"
                           x:Name="CurrentContentHeaderText"
                           FontWeight="SemiBold"
                           Text="Current editor content" />
                <TextBox Grid.Row="1"
                         x:Name="CurrentContentTextBox"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         FontFamily="Consolas"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Auto" />
            </Grid>
            <Grid Grid.Column="1"
                  RowDefinitions="Auto,*"
                  RowSpacing="6">
                <TextBlock Grid.Row="0"
                           x:Name="SelectedBackupHeaderText"
                           FontWeight="SemiBold"
                           Text="Selected backup content" />
                <TextBox Grid.Row="1"
                         x:Name="SelectedBackupContentTextBox"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         FontFamily="Consolas"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Auto" />
            </Grid>
        </Grid>

        <Grid Grid.Row="4"
              RowDefinitions="Auto,*"
              RowSpacing="6">
            <TextBlock Grid.Row="0"
                       x:Name="ComparisonHeaderText"
                       FontWeight="SemiBold"
                       Text="Line comparison" />
            <TextBox Grid.Row="1"
                     x:Name="ComparisonDiffTextBox"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="NoWrap"
                     FontFamily="Consolas"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto" />
        </Grid>

        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
            <Button x:Name="LoadIntoEditorButton"
                    Content="Load into editor"
                    IsEnabled="False"
                    Click="OnLoadIntoEditorClick" />
            <Button Content="Close"
                    Click="OnCloseClick" />
        </StackPanel>
    </Grid>
</Window>

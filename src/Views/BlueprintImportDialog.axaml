<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="myDUWorkbench.Views.BlueprintImportDialog"
        Width="720"
        MinWidth="660"
        Height="420"
        MinHeight="380"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    <Grid Margin="14"
          RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto"
          RowSpacing="10">
        <TextBlock Grid.Row="0"
                   FontWeight="SemiBold"
                   Text="Import blueprint file?" />

        <Grid Grid.Row="1"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="8">
            <TextBox Grid.Column="0"
                     x:Name="FilePathTextBox"
                     IsReadOnly="True"
                     Watermark="Click here to select a blueprint JSON file"
                     PointerPressed="OnFilePathPointerPressed" />
            <Button Grid.Column="1"
                    Content="Browse..."
                    Width="90"
                    Click="OnBrowseClick" />
        </Grid>

        <TextBlock Grid.Row="2"
                   x:Name="ValidationText"
                   Foreground="IndianRed"
                   IsVisible="False"
                   TextWrapping="Wrap"
                   Text="" />

        <Border Grid.Row="3"
                BorderThickness="1"
                BorderBrush="#505050"
                CornerRadius="4"
                Padding="8">
            <TextBlock TextWrapping="Wrap"
                       Text="Blueprint import can take some time, especially for large files. Please wait until the status bar confirms completion." />
        </Border>

        <StackPanel Grid.Row="4"
                    Spacing="6">
            <CheckBox x:Name="DryRunCheckBox"
                      Content="Dry run mode" />
            <CheckBox x:Name="ImportIntoAppCheckBox"
                      Content="Import into app" />
            <CheckBox x:Name="ImportIntoGameDatabaseCheckBox"
                      Content="Import into game database" />
            <CheckBox x:Name="AppendDateIfExistsCheckBox"
                      Content="Append date if BP exists" />
        </StackPanel>

        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Click="OnCancelClick" />
            <Button x:Name="ImportButton"
                    Content="Import"
                    Click="OnImportClick" />
        </StackPanel>
    </Grid>
</Window>

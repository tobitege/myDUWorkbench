<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:myDUWorkbench.ViewModels"
        xmlns:hier="clr-namespace:Avalonia.Controls.DataGridHierarchical;assembly=Avalonia.Controls.DataGrid"
        xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1280"
        d:DesignHeight="900"
        x:Class="myDUWorkbench.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="myDUWorkbench by tobitege"
        MinWidth="980"
        MinHeight="720">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid Margin="16"
          RowDefinitions="Auto,*,Auto"
          RowSpacing="10">
        <StackPanel Grid.Row="0"
                    Spacing="4">
            <TextBlock FontSize="22"
                       FontWeight="Bold"
                       Text="myDUWorkbench (c) 2026 by @tobitege" />
        </StackPanel>

        <Border x:Name="MainWorkbenchRoot"
                Grid.Row="1"
                Padding="0"
                BorderThickness="1"
                CornerRadius="0">
            <TabControl Padding="0">
                <TabItem Header="Constructs">
                    <Grid RowDefinitions="Auto,*"
                          RowSpacing="10">
                        <WrapPanel Orientation="Horizontal"
                                   ItemWidth="420">
                            <Border BorderThickness="1"
                                    BorderBrush="#505050"
                                    CornerRadius="4"
                                    Padding="8">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Construct Name Filter (wildcard * supported)" />
                                    <Grid ColumnDefinitions="150,*"
                                          ColumnSpacing="8">
                                        <TextBox Grid.Column="0"
                                                 Text="{Binding ConstructNameSearchInput}"
                                                 Width="150"
                                                 MaxWidth="150"
                                                 HorizontalAlignment="Left"
                                                 Watermark="Big or Big*">
                                            <TextBox.KeyBindings>
                                                <KeyBinding Gesture="Enter"
                                                            Command="{Binding UseConstructSuggestionAndLoadCommand}" />
                                            </TextBox.KeyBindings>
                                        </TextBox>
                                        <TextBlock Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding ConstructSearchStatus}" />
                                    </Grid>
                                    <Grid ColumnDefinitions="360,Auto"
                                          ColumnSpacing="6">
                                        <ComboBox Grid.Column="0"
                                                  ItemsSource="{Binding ConstructNameSuggestions}"
                                                  SelectedItem="{Binding SelectedConstructNameSuggestion}"
                                                  Width="360"
                                                  MaxWidth="360"
                                                  HorizontalAlignment="Left">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DisplayLabel}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                            <ComboBox.KeyBindings>
                                                <KeyBinding Gesture="Enter"
                                                            Command="{Binding UseConstructSuggestionAndLoadCommand}" />
                                            </ComboBox.KeyBindings>
                                        </ComboBox>
                                        <Button Grid.Column="1"
                                                Width="28"
                                                Height="28"
                                                Padding="0"
                                                Click="OnClearConstructSelectionClick"
                                                ToolTip.Tip="Clear selected construct">
                                            <PathIcon Width="14"
                                                      Height="14"
                                                      Data="M18.3 5.71 12 12l6.3 6.29-1.41 1.42L10.59 13.41 4.29 19.71 2.88 18.29 9.17 12 2.88 5.71 4.29 4.29l6.3 6.3 6.29-6.3z" />
                                        </Button>
                                    </Grid>
                                    <CheckBox Content="Limit to selected player constructs"
                                              IsChecked="{Binding LimitToSelectedPlayerConstructs}" />
                                </StackPanel>
                            </Border>

                            <Border BorderThickness="1"
                                    BorderBrush="#505050"
                                    CornerRadius="4"
                                    Padding="8">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Player Name Filter (wildcard * supported)" />
                                    <Grid ColumnDefinitions="180,Auto,*"
                                          ColumnSpacing="8">
                                        <TextBox Grid.Column="0"
                                                 Text="{Binding PlayerNameSearchInput}"
                                                 Width="150"
                                                 MaxWidth="150"
                                                 HorizontalAlignment="Left"
                                                 Watermark="tobi or tobi*" />
                                        <Button Grid.Column="1"
                                                Width="28"
                                                Height="28"
                                                Padding="0"
                                                Command="{Binding RefreshPlayerNamesCommand}"
                                                ToolTip.Tip="Refresh player list">
                                            <PathIcon Width="14"
                                                      Height="14"
                                                      Data="M17.65 6.35A8 8 0 1 0 20 12H18A6 6 0 1 1 16.24 7.76L13 11H20V4L17.65 6.35Z" />
                                        </Button>
                                        <TextBlock Grid.Column="2"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding PlayerSearchStatus}" />
                                    </Grid>
                                    <Grid ColumnDefinitions="360,Auto"
                                          ColumnSpacing="6">
                                        <ComboBox Grid.Column="0"
                                                  ItemsSource="{Binding PlayerNameSuggestions}"
                                                  SelectedItem="{Binding SelectedPlayerNameSuggestion}"
                                                  Width="360"
                                                  MaxWidth="360"
                                                  HorizontalAlignment="Left">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DisplayLabel}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <Button Grid.Column="1"
                                                Width="28"
                                                Height="28"
                                                Padding="0"
                                                Click="OnClearPlayerSelectionClick"
                                                ToolTip.Tip="Clear selected player">
                                            <PathIcon Width="14"
                                                      Height="14"
                                                      Data="M18.3 5.71 12 12l6.3 6.29-1.41 1.42L10.59 13.41 4.29 19.71 2.88 18.29 9.17 12 2.88 5.71 4.29 4.29l6.3 6.3 6.29-6.3z" />
                                        </Button>
                                    </Grid>
                                    <TextBlock Text="{Binding SelectedPlayerIdDisplay, StringFormat=Player ID: {0}}" />
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <TabControl Grid.Row="1"
                                    x:Name="ConstructDataTabControl"
                                    SelectedIndex="{Binding ConstructDataTabIndex, Mode=TwoWay}"
                                    Padding="0">
                            <TabItem Header="Construct Browser">
                                <Border Padding="0"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Margin="0,6,0,0">
                                    <Grid RowDefinitions="Auto,*"
                                          RowSpacing="8">
                                        <StackPanel Grid.Row="0"
                                                    Orientation="Horizontal"
                                                    Spacing="6"
                                                    HorizontalAlignment="Left">
                                            <Button Click="OnExpandAllElementPropertiesClick"
                                                    ToolTip.Tip="Expand all"
                                                    Padding="8,6">
                                                <PathIcon Width="14" Height="14" Data="M12 5.83L15.17 9l1.41-1.41L12 3 7.41 7.59 8.83 9 12 5.83zm0 12.34L8.83 15l-1.41 1.41L12 21l4.59-4.59L15.17 15 12 18.17z" />
                                            </Button>
                                            <Button Click="OnCollapseAllElementPropertiesClick"
                                                    ToolTip.Tip="Collapse all"
                                                    Padding="8,6">
                                                <PathIcon Width="14" Height="14" Data="M16.59 5.41L15.17 4 12 7.17 8.83 4 7.41 5.41 12 10l4.59-4.59zM12 14l-4.59 4.59L8.83 20 12 16.83 15.17 20l1.41-1.41L12 14z" />
                                            </Button>
                                            <TextBlock Text="Filter"
                                                       VerticalAlignment="Center"
                                                       Margin="10,0,0,0" />
                                            <ComboBox Width="240"
                                                      IsEditable="True"
                                                      Text="{Binding ElementTypeNameFilterInput}"
                                                      ItemsSource="{Binding ElementTypeFilterHistory}"
                                                      SelectedItem="{Binding SelectedElementTypeFilterHistoryItem}"
                                                      ToolTip.Tip="Wildcard filter applies to Element and Name columns. Examples: &#10;Big* = starts with Big&#10;*Engine* = contains Engine&#10;Anti-Gravity ?enerator = one-char wildcard&#10;Case-insensitive">
                                                <ComboBox.KeyBindings>
                                                    <KeyBinding Gesture="Enter"
                                                                Command="{Binding ApplyElementTypeNameFilterCommand}" />
                                                </ComboBox.KeyBindings>
                                            </ComboBox>
                                            <Button Width="90"
                                                    Command="{Binding ApplyElementTypeNameFilterCommand}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <PathIcon Width="14" Height="14" Data="M10 18h4v-2h-4v2zM3 6v2h18V6H3zm3 7h12v-2H6v2z" />
                                                    <TextBlock Text="Filter" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <CheckBox Content="Damaged"
                                                      VerticalAlignment="Center"
                                                      Margin="6,0,0,0"
                                                      IsEnabled="{Binding CanUseDamagedFilter}"
                                                      IsChecked="{Binding DamagedOnly}" />
                                            <Button Width="85"
                                                    Command="{Binding ClearElementTypeFilterHistoryCommand}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <PathIcon Width="14" Height="14" Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" />
                                                    <TextBlock Text="Clear" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Border Width="1"
                                                    Height="24"
                                                    Margin="10,0,6,0"
                                                    Background="#505050"
                                                    VerticalAlignment="Center" />
                                            <Button Content="Repair"
                                                    Width="90"
                                                    IsEnabled="{Binding CanRepairDestroyedElements}"
                                                    Click="OnRepairDestroyedElementsClick" />
                                            <DropDownButton Width="150"
                                                            IsEnabled="{Binding CanExportConstructBrowserElementSummary}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <PathIcon Width="14" Height="14" Data="M19 12v7H5v-7H3v7c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2v-7h-2zm-6 .67l2.59-2.58L17 11.5l-5-5-5 5 1.41 1.41L11 10.33V18h2v-5.33z" />
                                                    <TextBlock Text="Export to JSON" VerticalAlignment="Center" />
                                                </StackPanel>
                                                <DropDownButton.Flyout>
                                                    <MenuFlyout>
                                                        <MenuItem Header="Elements"
                                                                  Click="OnExportConstructBrowserElementSummaryClick" />
                                                        <MenuItem Header="Voxels"
                                                                  Click="OnExportConstructVoxelMaterialsJsonClick" />
                                                        <MenuItem Header="Both"
                                                                  Click="OnExportConstructBrowserBothJsonClick" />
                                                    </MenuFlyout>
                                                </DropDownButton.Flyout>
                                            </DropDownButton>
                                            <Button Content="Show Voxel Data"
                                                    Width="140"
                                                    IsEnabled="{Binding CanRepairDestroyedElements}"
                                                    Click="OnShowConstructVoxelDataClick" />
                                        </StackPanel>

                                        <DataGrid Grid.Row="1"
                                                  x:Name="ElementPropertiesGrid"
                                                  AutoGenerateColumns="False"
                                                  HierarchicalRowsEnabled="True"
                                                  HierarchicalModel="{Binding ElementPropertiesModel}"
                                                  SelectedItem="{Binding SelectedElementPropertyNode}"
                                                  SelectionMode="Extended"
                                                  CanUserSortColumns="True"
                                                  CanUserResizeColumns="True"
                                                  GridLinesVisibility="Horizontal"
                                                  UseLogicalScrollable="True">
                                            <DataGrid.Columns>
                                                <DataGridHierarchicalColumn Header="Node"
                                                                            SortMemberPath="Item.NodeLabel"
                                                                            Width="2*"
                                                                            MinWidth="180"
                                                                            x:CompileBindings="False">
                                                    <DataGridHierarchicalColumn.CellTemplate>
                                                        <DataTemplate x:DataType="hier:HierarchicalNode">
                                                            <TextBlock Text="{Binding Item.NodeLabel}" />
                                                        </DataTemplate>
                                                    </DataGridHierarchicalColumn.CellTemplate>
                                                </DataGridHierarchicalColumn>
                                                <DataGridTemplateColumn Header="Name"
                                                                        SortMemberPath="Item.ElementName"
                                                                        Width="1.3*"
                                                                        MinWidth="130"
                                                                        x:CompileBindings="False">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate x:DataType="hier:HierarchicalNode">
                                                            <TextBlock Text="{Binding Item.ElementName}" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="ElementId"
                                                                        SortMemberPath="Item.ElementId"
                                                                        Width="120"
                                                                        MinWidth="100"
                                                                        x:CompileBindings="False">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate x:DataType="hier:HierarchicalNode">
                                                            <TextBlock Text="{Binding Item.ElementIdText}" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="Element"
                                                                        SortMemberPath="Item.ElementTypeName"
                                                                        Width="2*"
                                                                        MinWidth="180"
                                                                        x:CompileBindings="False">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate x:DataType="hier:HierarchicalNode">
                                                            <TextBlock Text="{Binding Item.ElementTypeName}" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="Property"
                                                                        SortMemberPath="Item.PropertyName"
                                                                        Width="*"
                                                                        MinWidth="130"
                                                                        x:CompileBindings="False">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate x:DataType="hier:HierarchicalNode">
                                                            <TextBlock Text="{Binding Item.PropertyName}" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="Type"
                                                                        SortMemberPath="Item.PropertyType"
                                                                        Width="90"
                                                                        MinWidth="70"
                                                                        x:CompileBindings="False">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate x:DataType="hier:HierarchicalNode">
                                                            <TextBlock Text="{Binding Item.PropertyTypeText}" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="Bytes"
                                                                        SortMemberPath="Item.ByteLength"
                                                                        Width="90"
                                                                        MinWidth="70"
                                                                        x:CompileBindings="False">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate x:DataType="hier:HierarchicalNode">
                                                            <TextBlock Text="{Binding Item.ByteLengthText}" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="Preview"
                                                                        SortMemberPath="Item.ValuePreview"
                                                                        Width="3*"
                                                                        MinWidth="220"
                                                                        x:CompileBindings="False">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate x:DataType="hier:HierarchicalNode">
                                                            <TextBlock Text="{Binding Item.ValuePreview}" TextWrapping="Wrap" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>
                            </TabItem>

                            <TabItem Header="Blueprints">
                                <Border Padding="0"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Margin="0,6,0,0">
                                    <Grid RowSpacing="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="6" />
                                            <RowDefinition Height="230"
                                                           MinHeight="190"
                                                           MaxHeight="230" />
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0"
                                              RowDefinitions="Auto,Auto"
                                              RowSpacing="6">
                                            <StackPanel Grid.Row="0"
                                                        Orientation="Horizontal"
                                                        Spacing="6"
                                                        HorizontalAlignment="Left">
                                                <TextBlock Text="Name filter"
                                                           VerticalAlignment="Center"
                                                           Margin="6,0,0,0" />
                                                <TextBox Width="200"
                                                         Text="{Binding BlueprintNameFilter}"
                                                         Watermark="MyBlueprint or My*">
                                                    <TextBox.KeyBindings>
                                                        <KeyBinding Gesture="Enter"
                                                                    Command="{Binding LoadBlueprintsCommand}" />
                                                    </TextBox.KeyBindings>
                                                </TextBox>
                                                <Button Width="140"
                                                        Command="{Binding LoadBlueprintsCommand}">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <PathIcon Width="14" Height="14" Data="M17.65 6.35A8 8 0 1 0 20 12H18A6 6 0 1 1 16.24 7.76L13 11H20V4L17.65 6.35Z" />
                                                        <TextBlock Text="Load / Refresh" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>

                                            <StackPanel Grid.Row="1"
                                                        Orientation="Horizontal"
                                                        Spacing="6"
                                                        HorizontalAlignment="Left">
                                                <Button Width="85"
                                                        IsEnabled="{Binding CanCopyBlueprint}"
                                                        Click="OnCopyBlueprintClick">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <PathIcon Width="14" Height="14" Data="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z" />
                                                        <TextBlock Text="Copy" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Width="90"
                                                        IsEnabled="{Binding CanDeleteBlueprint}"
                                                        Click="OnDeleteBlueprintClick">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <PathIcon Width="14" Height="14" Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" />
                                                        <TextBlock Text="Delete" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Content="Import Blueprint"
                                                        Width="130"
                                                        IsEnabled="{Binding CanImportBlueprint}"
                                                        Click="OnImportBlueprintClick" />
                                                <Button Width="130"
                                                        IsEnabled="{Binding CanEditBlueprint}"
                                                        Click="OnExportBlueprintJsonClick">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <PathIcon Width="14" Height="14" Data="M19 12v7H5v-7H3v7c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2v-7h-2zm-6 .67l2.59-2.58L17 11.5l-5-5-5 5 1.41 1.41L11 10.33V18h2v-5.33z" />
                                                        <TextBlock Text="Export JSON" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                                <DropDownButton Width="150"
                                                                IsEnabled="{Binding CanExportBlueprintElementSummary}">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <PathIcon Width="14" Height="14" Data="M19 12v7H5v-7H3v7c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2v-7h-2zm-6 .67l2.59-2.58L17 11.5l-5-5-5 5 1.41 1.41L11 10.33V18h2v-5.33z" />
                                                        <TextBlock Text="Export to JSON" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                    <DropDownButton.Flyout>
                                                        <MenuFlyout>
                                                            <MenuItem Header="Elements"
                                                                      Click="OnExportBlueprintElementSummaryClick" />
                                                            <MenuItem Header="Voxels"
                                                                      Click="OnExportBlueprintVoxelMaterialsJsonClick" />
                                                            <MenuItem Header="Both"
                                                                      Click="OnExportBlueprintBothJsonClick" />
                                                        </MenuFlyout>
                                                    </DropDownButton.Flyout>
                                                </DropDownButton>
                                                <Button Content="Show Voxel Data"
                                                        Width="140"
                                                        IsEnabled="{Binding CanEditBlueprint}"
                                                        Click="OnShowBlueprintVoxelDataClick" />
                                                <Button Content="Open in Construct Browser"
                                                        Width="210"
                                                        IsEnabled="{Binding CanEditBlueprint}"
                                                        Click="OnOpenBlueprintInConstructBrowserClick" />
                                                <TextBlock VerticalAlignment="Center"
                                                           Foreground="#A0A0A0"
                                                           Text="{Binding BlueprintsPlayerFilterDisplay}" />
                                                <TextBlock VerticalAlignment="Center"
                                                           Foreground="DarkOrange"
                                                           Text="{Binding BlueprintsStatus}" />
                                            </StackPanel>
                                        </Grid>

                                        <DataGrid Grid.Row="1"
                                                  x:Name="BlueprintsGrid"
                                                  AutoGenerateColumns="False"
                                                  ItemsSource="{Binding Blueprints}"
                                                  SelectedItem="{Binding SelectedBlueprint}"
                                                  SelectionMode="Extended"
                                                  CanUserSortColumns="True"
                                                  CanUserResizeColumns="True"
                                                  GridLinesVisibility="Horizontal"
                                                  UseLogicalScrollable="True">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="ID"
                                                                    Binding="{Binding Id}"
                                                                    Width="SizeToHeader"
                                                                    MinWidth="60" />
                                                <DataGridTextColumn Header="Name"
                                                                    Binding="{Binding Name}"
                                                                    Width="3*"
                                                                    MinWidth="160" />
                                                <DataGridTextColumn Header="Creator ID"
                                                                    Binding="{Binding CreatorIdDisplay}"
                                                                    Width="SizeToHeader"
                                                                    MinWidth="70" />
                                                <DataGridTextColumn Header="Created"
                                                                    Binding="{Binding CreatedAtDisplay}"
                                                                    Width="SizeToHeader"
                                                                    MinWidth="120" />
                                                <DataGridTemplateColumn Header="Free Deploy"
                                                                        SortMemberPath="FreeDeploy"
                                                                        Width="SizeToHeader"
                                                                        MinWidth="70">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <CheckBox IsChecked="{Binding FreeDeploy}"
                                                                      IsHitTestVisible="False"
                                                                      HorizontalAlignment="Center" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Header="Max Use"
                                                                    Binding="{Binding MaxUseDisplay}"
                                                                    Width="SizeToHeader"
                                                                    MinWidth="60" />
                                                <DataGridTextColumn Header="Elements"
                                                                    Binding="{Binding ElementCount}"
                                                                    Width="SizeToHeader"
                                                                    MinWidth="60" />
                                            </DataGrid.Columns>
                                        </DataGrid>

                                        <GridSplitter Grid.Row="2"
                                                      Height="6"
                                                      HorizontalAlignment="Stretch"
                                                      ResizeDirection="Rows"
                                                      Background="#505050" />

                                        <Border Grid.Row="3"
                                                BorderThickness="1"
                                                BorderBrush="#505050"
                                                CornerRadius="4"
                                                Padding="10"
                                                Margin="0,0,0,6">
                                            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                                                  RowSpacing="8">
                                                <TextBlock Grid.Row="0"
                                                           FontWeight="SemiBold"
                                                           Text="Edit selected blueprint" />

                                                <Grid Grid.Row="1"
                                                      ColumnDefinitions="100,*"
                                                      ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0"
                                                               VerticalAlignment="Center"
                                                               Text="Name" />
                                                    <TextBox Grid.Column="1"
                                                             Text="{Binding BlueprintEditName}"
                                                             MaxLength="30"
                                                             IsEnabled="{Binding CanEditBlueprint}" />
                                                </Grid>

                                                <Grid Grid.Row="2"
                                                      ColumnDefinitions="100,Auto,70,Auto,*"
                                                      ColumnSpacing="12">
                                                    <TextBlock Grid.Column="0"
                                                               VerticalAlignment="Center"
                                                               Text="Free Deploy" />
                                                    <CheckBox Grid.Column="1"
                                                              IsChecked="{Binding BlueprintEditFreeDeploy}"
                                                              IsEnabled="{Binding CanEditBlueprint}" />
                                                    <TextBlock Grid.Column="2"
                                                               VerticalAlignment="Center"
                                                               Text="Change usage:" />
                                                    <CheckBox Grid.Column="3"
                                                              VerticalAlignment="Center"
                                                              IsChecked="{Binding BlueprintEditApplyMaxUse}"
                                                              IsEnabled="{Binding CanEditBlueprint}" />
                                                    <StackPanel Grid.Column="4"
                                                                Orientation="Horizontal"
                                                                Spacing="12">
                                                        <RadioButton Content="Core BP (unlimited)"
                                                                     GroupName="BlueprintMaxUseType"
                                                                     IsChecked="{Binding BlueprintEditCoreBlueprint}"
                                                                     IsEnabled="{Binding CanEditBlueprintMaxUse}" />
                                                        <RadioButton Content="Single-use BP"
                                                                     GroupName="BlueprintMaxUseType"
                                                                     IsChecked="{Binding BlueprintEditSingleUseBlueprint}"
                                                                     IsEnabled="{Binding CanEditBlueprintMaxUse}" />
                                                    </StackPanel>
                                                </Grid>

                                                <TextBlock Grid.Row="3"
                                                           Foreground="#A0A0A0"
                                                           Text="{Binding BlueprintCurrentMaxUseStateDisplay}"
                                                           IsVisible="{Binding CanEditBlueprint}" />

                                                <TextBlock Grid.Row="4"
                                                           Foreground="IndianRed"
                                                           Text="{Binding BlueprintEditValidationMessage}"
                                                           IsVisible="{Binding HasBlueprintEditValidationError}" />

                                                <Button Grid.Row="5"
                                                        Content="Save changes"
                                                        Width="120"
                                                        HorizontalAlignment="Left"
                                                        IsEnabled="{Binding CanSaveBlueprint}"
                                                        Command="{Binding SaveBlueprintCommand}" />
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
                            </TabItem>

                            <TabItem Header="LUA blocks">
                                <Border Padding="10"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Margin="0,6,0,0">
                                    <Grid RowDefinitions="Auto,3*,Auto,4*"
                                          RowSpacing="8">
                                        <StackPanel Grid.Row="0"
                                                    Orientation="Horizontal"
                                                    Spacing="10"
                                                    HorizontalAlignment="Left">
                                            <Button Click="OnExpandAllLuaBlocksClick"
                                                    ToolTip.Tip="Expand all"
                                                    Padding="8,6">
                                                <PathIcon Width="14" Height="14" Data="M12 5.83L15.17 9l1.41-1.41L12 3 7.41 7.59 8.83 9 12 5.83zm0 12.34L8.83 15l-1.41 1.41L12 21l4.59-4.59L15.17 15 12 18.17z" />
                                            </Button>
                                            <Button Click="OnCollapseAllLuaBlocksClick"
                                                    ToolTip.Tip="Collapse all"
                                                    Padding="8,6">
                                                <PathIcon Width="14" Height="14" Data="M16.59 5.41L15.17 4 12 7.17 8.83 4 7.41 5.41 12 10l4.59-4.59zM12 14l-4.59 4.59L8.83 20 12 16.83 15.17 20l1.41-1.41L12 14z" />
                                            </Button>
                                            <Button Click="OnSaveLuaAsClick"
                                                    IsEnabled="{Binding CanSaveSelectedLuaBlob}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <PathIcon Width="14" Height="14" Data="M17 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z" />
                                                    <TextBlock Text="Save as..." VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Button Click="OnEditLuaClick"
                                                    IsEnabled="{Binding CanSaveSelectedLuaBlob}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <PathIcon Width="14" Height="14" Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" />
                                                    <TextBlock Text="Edit" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <CheckBox IsChecked="{Binding AutoWrapContent}"
                                                      Width="120">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <PathIcon Width="14" Height="14" Data="M4 19h6v-2H4v2zM20 5H4v2h16V5zm-3 6H4v2h13.25c1.1 0 2 .9 2 2s-.9 2-2 2H15v-2l-3 3 3 3v-2h2c2.21 0 4-1.79 4-4s-1.79-4-4-4z" />
                                                    <TextBlock Text="Auto-wrap" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </CheckBox>
                                        </StackPanel>

                                        <DataGrid x:Name="LuaBlocksGrid"
                                                  Grid.Row="1"
                                                  AutoGenerateColumns="False"
                                                  HierarchicalRowsEnabled="True"
                                                  HierarchicalModel="{Binding Dpuyaml6Model}"
                                                  SelectedItem="{Binding SelectedDpuyaml6Node}"
                                                  CanUserSortColumns="True"
                                                  CanUserResizeColumns="True"
                                                  GridLinesVisibility="Horizontal"
                                                  UseLogicalScrollable="True">
                                            <DataGrid.Columns>
                                                <DataGridHierarchicalColumn Header="Node"
                                                                            SortMemberPath="Item.NodeLabel"
                                                                            Width="2*"
                                                                            MinWidth="180"
                                                                            x:CompileBindings="False">
                                                    <DataGridHierarchicalColumn.CellTemplate>
                                                        <DataTemplate x:DataType="hier:HierarchicalNode">
                                                            <TextBlock Text="{Binding Item.NodeLabel}" />
                                                        </DataTemplate>
                                                    </DataGridHierarchicalColumn.CellTemplate>
                                                </DataGridHierarchicalColumn>
                                                <DataGridTemplateColumn Header="ElementId"
                                                                        SortMemberPath="Item.ElementId"
                                                                        Width="120"
                                                                        MinWidth="100"
                                                                        x:CompileBindings="False">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate x:DataType="hier:HierarchicalNode">
                                                            <TextBlock Text="{Binding Item.ElementIdText}" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="Preview"
                                                                        SortMemberPath="Item.ValuePreview"
                                                                        Width="3*"
                                                                        MinWidth="220"
                                                                        x:CompileBindings="False">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate x:DataType="hier:HierarchicalNode">
                                                            <TextBlock Text="{Binding Item.ValuePreview}" TextWrapping="Wrap" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>

                                        <GridSplitter Grid.Row="2"
                                                      Height="6"
                                                      HorizontalAlignment="Stretch"
                                                      ResizeDirection="Rows"
                                                      Background="#505050" />

                                        <TextBox Grid.Row="3"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 TextWrapping="{Binding ContentTextWrapping}"
                                                 FontFamily="Consolas"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 Text="{Binding SelectedDpuyaml6Content}" />
                                    </Grid>
                                </Border>
                            </TabItem>

                            <TabItem Header="HTML/RS">
                                <Border Padding="10"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Margin="0,6,0,0">
                                    <Grid RowDefinitions="Auto,3*,Auto,4*"
                                          RowSpacing="8">
                                        <StackPanel Grid.Row="0"
                                                    Orientation="Horizontal"
                                                    Spacing="10"
                                                    HorizontalAlignment="Left">
                                            <Button Click="OnExpandAllHtmlRsClick"
                                                    ToolTip.Tip="Expand all"
                                                    Padding="8,6">
                                                <PathIcon Width="14" Height="14" Data="M12 5.83L15.17 9l1.41-1.41L12 3 7.41 7.59 8.83 9 12 5.83zm0 12.34L8.83 15l-1.41 1.41L12 21l4.59-4.59L15.17 15 12 18.17z" />
                                            </Button>
                                            <Button Click="OnCollapseAllHtmlRsClick"
                                                    ToolTip.Tip="Collapse all"
                                                    Padding="8,6">
                                                <PathIcon Width="14" Height="14" Data="M16.59 5.41L15.17 4 12 7.17 8.83 4 7.41 5.41 12 10l4.59-4.59zM12 14l-4.59 4.59L8.83 20 12 16.83 15.17 20l1.41-1.41L12 14z" />
                                            </Button>
                                            <Button Click="OnSaveHtmlRsAsClick"
                                                    IsEnabled="{Binding CanSaveSelectedHtmlRsBlob}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <PathIcon Width="14" Height="14" Data="M17 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z" />
                                                    <TextBlock Text="Save as..." VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <CheckBox IsChecked="{Binding AutoWrapContent}"
                                                      Width="120">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <PathIcon Width="14" Height="14" Data="M4 19h6v-2H4v2zM20 5H4v2h16V5zm-3 6H4v2h13.25c1.1 0 2 .9 2 2s-.9 2-2 2H15v-2l-3 3 3 3v-2h2c2.21 0 4-1.79 4-4s-1.79-4-4-4z" />
                                                    <TextBlock Text="Auto-wrap" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </CheckBox>
                                        </StackPanel>

                                        <DataGrid x:Name="HtmlRsGrid"
                                                  Grid.Row="1"
                                                  AutoGenerateColumns="False"
                                                  HierarchicalRowsEnabled="True"
                                                  HierarchicalModel="{Binding Content2Model}"
                                                  SelectedItem="{Binding SelectedContent2Node}"
                                                  CanUserSortColumns="True"
                                                  CanUserResizeColumns="True"
                                                  GridLinesVisibility="Horizontal"
                                                  UseLogicalScrollable="True">
                                            <DataGrid.Columns>
                                                <DataGridHierarchicalColumn Header="Node"
                                                                            SortMemberPath="Item.NodeLabel"
                                                                            Width="2*"
                                                                            MinWidth="180"
                                                                            x:CompileBindings="False">
                                                    <DataGridHierarchicalColumn.CellTemplate>
                                                        <DataTemplate x:DataType="hier:HierarchicalNode">
                                                            <TextBlock Text="{Binding Item.NodeLabel}" />
                                                        </DataTemplate>
                                                    </DataGridHierarchicalColumn.CellTemplate>
                                                </DataGridHierarchicalColumn>
                                                <DataGridTemplateColumn Header="ElementId"
                                                                        SortMemberPath="Item.ElementId"
                                                                        Width="120"
                                                                        MinWidth="100"
                                                                        x:CompileBindings="False">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate x:DataType="hier:HierarchicalNode">
                                                            <TextBlock Text="{Binding Item.ElementIdText}" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="Preview"
                                                                        SortMemberPath="Item.ValuePreview"
                                                                        Width="3*"
                                                                        MinWidth="220"
                                                                        x:CompileBindings="False">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate x:DataType="hier:HierarchicalNode">
                                                            <TextBlock Text="{Binding Item.ValuePreview}" TextWrapping="Wrap" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>

                                        <GridSplitter Grid.Row="2"
                                                      Height="6"
                                                      HorizontalAlignment="Stretch"
                                                      ResizeDirection="Rows"
                                                      Background="#505050" />

                                        <TextBox Grid.Row="3"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 TextWrapping="{Binding ContentTextWrapping}"
                                                 FontFamily="Consolas"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 Text="{Binding SelectedContent2Content}" />
                                    </Grid>
                                </Border>
                            </TabItem>

                            <TabItem Header="Databank">
                                <Border Padding="10"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Margin="0,6,0,0">
                                    <Grid RowDefinitions="Auto,3*,Auto,4*"
                                          RowSpacing="8">
                                        <StackPanel Grid.Row="0"
                                                    Orientation="Horizontal"
                                                    Spacing="10"
                                                    HorizontalAlignment="Left">
                                            <Button Click="OnExpandAllDatabankClick"
                                                    ToolTip.Tip="Expand all"
                                                    Padding="8,6">
                                                <PathIcon Width="14" Height="14" Data="M12 5.83L15.17 9l1.41-1.41L12 3 7.41 7.59 8.83 9 12 5.83zm0 12.34L8.83 15l-1.41 1.41L12 21l4.59-4.59L15.17 15 12 18.17z" />
                                            </Button>
                                            <Button Click="OnCollapseAllDatabankClick"
                                                    ToolTip.Tip="Collapse all"
                                                    Padding="8,6">
                                                <PathIcon Width="14" Height="14" Data="M16.59 5.41L15.17 4 12 7.17 8.83 4 7.41 5.41 12 10l4.59-4.59zM12 14l-4.59 4.59L8.83 20 12 16.83 15.17 20l1.41-1.41L12 14z" />
                                            </Button>
                                            <Button Click="OnSaveDatabankAsClick"
                                                    IsEnabled="{Binding CanSaveSelectedDatabankBlob}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <PathIcon Width="14" Height="14" Data="M17 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z" />
                                                    <TextBlock Text="Save as..." VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <CheckBox IsChecked="{Binding AutoWrapContent}"
                                                      Width="120">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <PathIcon Width="14" Height="14" Data="M4 19h6v-2H4v2zM20 5H4v2h16V5zm-3 6H4v2h13.25c1.1 0 2 .9 2 2s-.9 2-2 2H15v-2l-3 3 3 3v-2h2c2.21 0 4-1.79 4-4s-1.79-4-4-4z" />
                                                    <TextBlock Text="Auto-wrap" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </CheckBox>
                                        </StackPanel>

                                        <DataGrid x:Name="DatabankGrid"
                                                  Grid.Row="1"
                                                  AutoGenerateColumns="False"
                                                  HierarchicalRowsEnabled="True"
                                                  HierarchicalModel="{Binding DatabankModel}"
                                                  SelectedItem="{Binding SelectedDatabankNode}"
                                                  CanUserSortColumns="True"
                                                  CanUserResizeColumns="True"
                                                  GridLinesVisibility="Horizontal"
                                                  UseLogicalScrollable="True">
                                            <DataGrid.Columns>
                                                <DataGridHierarchicalColumn Header="Node"
                                                                            SortMemberPath="Item.NodeLabel"
                                                                            Width="2*"
                                                                            MinWidth="180"
                                                                            x:CompileBindings="False">
                                                    <DataGridHierarchicalColumn.CellTemplate>
                                                        <DataTemplate x:DataType="hier:HierarchicalNode">
                                                            <TextBlock Text="{Binding Item.NodeLabel}" />
                                                        </DataTemplate>
                                                    </DataGridHierarchicalColumn.CellTemplate>
                                                </DataGridHierarchicalColumn>
                                                <DataGridTemplateColumn Header="Kind"
                                                                        SortMemberPath="Item.NodeKind"
                                                                        Width="120"
                                                                        MinWidth="90"
                                                                        x:CompileBindings="False">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate x:DataType="hier:HierarchicalNode">
                                                            <TextBlock Text="{Binding Item.NodeKind}" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="ElementId"
                                                                        SortMemberPath="Item.ElementId"
                                                                        Width="120"
                                                                        MinWidth="100"
                                                                        x:CompileBindings="False">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate x:DataType="hier:HierarchicalNode">
                                                            <TextBlock Text="{Binding Item.ElementIdText}" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="Preview"
                                                                        SortMemberPath="Item.ValuePreview"
                                                                        Width="3*"
                                                                        MinWidth="220"
                                                                        x:CompileBindings="False">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate x:DataType="hier:HierarchicalNode">
                                                            <TextBlock Text="{Binding Item.ValuePreview}" TextWrapping="Wrap" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>

                                        <GridSplitter Grid.Row="2"
                                                      Height="6"
                                                      HorizontalAlignment="Stretch"
                                                      ResizeDirection="Rows"
                                                      Background="#505050" />

                                        <TextBox Grid.Row="3"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 TextWrapping="{Binding ContentTextWrapping}"
                                                 FontFamily="Consolas"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 Text="{Binding SelectedDatabankContent}" />
                                    </Grid>
                                </Border>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </TabItem>

                <TabItem Header="Database">
                    <Grid RowDefinitions="Auto,*"
                          RowSpacing="10">
                        <WrapPanel Grid.Row="0"
                                   Orientation="Horizontal"
                                   ItemWidth="380"
                                   ItemHeight="84">
                            <Border BorderThickness="1"
                                    BorderBrush="#505050"
                                    CornerRadius="4"
                                    Padding="8">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="DB Host" />
                                    <TextBox Text="{Binding DbHostInput}"
                                             Width="200"
                                             MaxWidth="200"
                                             HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>

                            <Border BorderThickness="1"
                                    BorderBrush="#505050"
                                    CornerRadius="4"
                                    Padding="8">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="DB Port" />
                                    <TextBox Text="{Binding DbPortInput}"
                                             Width="200"
                                             MaxWidth="200"
                                             HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>

                            <Border BorderThickness="1"
                                    BorderBrush="#505050"
                                    CornerRadius="4"
                                    Padding="8">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="DB Name" />
                                    <TextBox Text="{Binding DbNameInput}"
                                             Width="200"
                                             MaxWidth="200"
                                             HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>

                            <Border BorderThickness="1"
                                    BorderBrush="#505050"
                                    CornerRadius="4"
                                    Padding="8">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="DB User" />
                                    <TextBox Text="{Binding DbUserInput}"
                                             Width="200"
                                             MaxWidth="200"
                                             HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>

                            <Border BorderThickness="1"
                                    BorderBrush="#505050"
                                    CornerRadius="4"
                                    Padding="8">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="DB Password" />
                                    <TextBox Text="{Binding DbPasswordInput}"
                                             PasswordChar="*"
                                             Width="200"
                                             MaxWidth="200"
                                             HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>

                            <Border BorderThickness="1"
                                    BorderBrush="#505050"
                                    CornerRadius="4"
                                    Padding="8">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Property Limit / Element" />
                                    <TextBox Text="{Binding PropertyLimitInput}"
                                             Width="200"
                                             MaxWidth="200"
                                             HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>

                            <Border BorderThickness="1"
                                    BorderBrush="#505050"
                                    CornerRadius="4"
                                    Padding="8">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Server Root Path" />
                                    <TextBox Text="{Binding ServerRootPathInput}"
                                             Width="360"
                                             MaxWidth="360"
                                             HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>

                            <Border BorderThickness="1"
                                    BorderBrush="#505050"
                                    CornerRadius="4"
                                    Padding="8">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Connection" />
                                    <Button Command="{Binding ConnectDatabaseCommand}"
                                            Width="140"
                                            HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <PathIcon Width="14" Height="14" Data="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z" />
                                            <TextBlock Text="Connect now" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <TabControl Grid.Row="1" Padding="0">
                            <TabItem Header="Database Summary">
                                <Border Padding="10"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Margin="0,6,0,0">
                                    <TextBox IsReadOnly="True"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             HorizontalAlignment="Stretch"
                                             VerticalAlignment="Stretch"
                                             Text="{Binding DatabaseSummary}" />
                                </Border>
                            </TabItem>

                            <TabItem Header="Endpoint">
                                <Border Padding="10"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Margin="0,6,0,0">
                                    <Grid RowDefinitions="Auto,Auto,2*,3*"
                                          RowSpacing="8">
                                        <Grid Grid.Row="0"
                                              ColumnDefinitions="Auto,*"
                                              ColumnSpacing="8">
                                            <TextBlock Grid.Column="0"
                                                       VerticalAlignment="Center"
                                                       Text="Endpoint Template" />
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding EndpointTemplateInput}" />
                                        </Grid>

                                        <WrapPanel Grid.Row="1"
                                                   ItemWidth="200"
                                                   HorizontalAlignment="Left">
                                            <Button Content="Probe Endpoint Binary"
                                                    Command="{Binding ProbeEndpointCommand}" />
                                        </WrapPanel>

                                        <Grid Grid.Row="2"
                                              RowDefinitions="Auto,*"
                                              RowSpacing="6">
                                            <TextBlock Grid.Row="0"
                                                       FontWeight="SemiBold"
                                                       Text="Endpoint Summary" />
                                            <TextBox Grid.Row="1"
                                                     IsReadOnly="True"
                                                     AcceptsReturn="True"
                                                     TextWrapping="Wrap"
                                                     HorizontalAlignment="Stretch"
                                                     VerticalAlignment="Stretch"
                                                     Text="{Binding EndpointSummary}" />
                                        </Grid>

                                        <Grid Grid.Row="3"
                                              RowDefinitions="Auto,*"
                                              RowSpacing="6">
                                            <TextBlock Grid.Row="0"
                                                       FontWeight="SemiBold"
                                                       Text="Endpoint Raw Preview" />
                                            <TextBox Grid.Row="1"
                                                     IsReadOnly="True"
                                                     AcceptsReturn="True"
                                                     TextWrapping="Wrap"
                                                     HorizontalAlignment="Stretch"
                                                     VerticalAlignment="Stretch"
                                                     Text="{Binding EndpointRawPreview}" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </TabItem>

                <TabItem Header="Config">
                    <Border BorderThickness="1"
                            BorderBrush="#505050"
                            CornerRadius="4"
                            Padding="8">
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*"
                              RowSpacing="8">
                            <CheckBox Grid.Row="0"
                                      Content="Auto-load on startup"
                                      IsChecked="{Binding AutoLoadOnStartup}" />

                            <CheckBox Grid.Row="1"
                                      Content="Auto-connect database when offline"
                                      IsChecked="{Binding AutoConnectDatabase}" />

                            <StackPanel Grid.Row="2"
                                        Orientation="Horizontal"
                                        Spacing="10"
                                        VerticalAlignment="Center">
                                <TextBlock VerticalAlignment="Center"
                                           Text="Auto-connect retry interval (seconds)" />
                                <NumericUpDown Minimum="10"
                                               Maximum="9999"
                                               Increment="1"
                                               FormatString="F0"
                                               Value="{Binding AutoConnectRetrySeconds, Mode=TwoWay}"
                                               Width="120" />
                            </StackPanel>

                            <CheckBox Grid.Row="3"
                                      Content="Auto-wrap content panes"
                                      IsChecked="{Binding AutoWrapContent}" />

                            <CheckBox Grid.Row="4"
                                      Content="Auto-collapse to 1st level"
                                      IsChecked="{Binding AutoCollapseToFirstLevel}" />

                            <CheckBox Grid.Row="5"
                                      Content="LUA versioning backups"
                                      IsChecked="{Binding LuaVersioningEnabled}" />

                            <CheckBox Grid.Row="6"
                                      Content="Auto-load player names"
                                      IsChecked="{Binding AutoLoadPlayerNames}" />

                            <StackPanel Grid.Row="7"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center">
                                <TextBlock VerticalAlignment="Center"
                                           Text="Element properties listed by default:" />
                                <TextBlock VerticalAlignment="Center"
                                           Margin="8,0,0,0"
                                           Text="Check:" />
                                <Button Content="All"
                                        MinWidth="56"
                                        Command="{Binding CheckAllElementPropertyFiltersCommand}" />
                                <Button Content="None"
                                        MinWidth="56"
                                        Command="{Binding UncheckAllElementPropertyFiltersCommand}" />
                            </StackPanel>

                            <StackPanel Grid.Row="8"
                                        Orientation="Vertical"
                                        Spacing="4">
                                <TextBlock Text="NQutils.dll path (optional, explicit override)" />
                                <TextBox Text="{Binding NqUtilsDllPathInput}"
                                         Watermark="D:\MyDUserver\wincs\all\NQutils.dll" />
                            </StackPanel>

                            <StackPanel Grid.Row="9"
                                        Orientation="Vertical"
                                        Spacing="4">
                                <TextBlock Text="Blueprint import endpoint (optional override)" />
                                <TextBox Text="{Binding BlueprintImportEndpointInput}"
                                         Watermark="http://127.0.0.1:10111/blueprint/import" />
                            </StackPanel>

                            <DataGrid Grid.Row="10"
                                      x:Name="ConfigPropertiesGrid"
                                      AutoGenerateColumns="False"
                                      CanUserSortColumns="True"
                                      CanUserResizeColumns="True"
                                      GridLinesVisibility="Horizontal"
                                      UseLogicalScrollable="True"
                                      ItemsSource="{Binding ElementPropertyFilters}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Property"
                                                        Binding="{Binding PropertyName}"
                                                        Width="*"
                                                        MinWidth="180" />
                                    <DataGridTemplateColumn Header="Active"
                                                            Width="120"
                                                            MinWidth="90"
                                                            x:CompileBindings="False">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox HorizontalAlignment="Center"
                                                          IsChecked="{Binding IsActive, Mode=TwoWay}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </TabItem>
            </TabControl>
        </Border>

        <Border x:Name="LuaEditorPageRoot"
                Grid.Row="1"
                Padding="10"
                BorderThickness="1"
                CornerRadius="6"
                IsVisible="False">
            <Grid RowDefinitions="Auto,Auto,*,Auto"
                  RowSpacing="8">
                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            Spacing="10">
                    <Button Content="&lt;&lt; Back"
                            Click="OnLuaEditorBackClick" />
                    <TextBlock x:Name="LuaEditorHeaderText"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Text="LUA Editor" />
                </StackPanel>

                <WrapPanel Grid.Row="1"
                           Orientation="Horizontal"
                           HorizontalAlignment="Left"
                           ItemWidth="110">
                    <Button Content="New"
                            Click="OnLuaEditorNewClick" />
                    <Button Content="Open..."
                            Click="OnLuaEditorOpenClick" />
                    <Button x:Name="LuaEditorSaveButton"
                            Content="Save"
                            Click="OnLuaEditorSaveClick" />
                    <Button Click="OnLuaEditorSaveAsClick">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Width="14" Height="14" Data="M17 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z" />
                            <TextBlock Text="Save as..." VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="LuaEditorSaveToDbButton"
                            Content="Save to DB"
                            Click="OnLuaEditorSaveToDbClick" />
                    <Button Content="Backups..."
                            Click="OnLuaEditorBackupsClick" />
                    <Button Content="Undo"
                            Click="OnLuaEditorUndoClick" />
                    <Button Content="Redo"
                            Click="OnLuaEditorRedoClick" />
                    <Button Content="Cut"
                            Click="OnLuaEditorCutClick" />
                    <Button Click="OnLuaEditorCopyClick">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Width="14" Height="14" Data="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z" />
                            <TextBlock Text="Copy" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Content="Paste"
                            Click="OnLuaEditorPasteClick" />
                    <ToggleButton x:Name="LuaEditorWordWrapToggle"
                                  IsChecked="False"
                                  Checked="OnLuaEditorWordWrapChanged"
                                  Unchecked="OnLuaEditorWordWrapChanged">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Width="14" Height="14" Data="M4 19h6v-2H4v2zM20 5H4v2h16V5zm-3 6H4v2h13.25c1.1 0 2 .9 2 2s-.9 2-2 2H15v-2l-3 3 3 3v-2h2c2.21 0 4-1.79 4-4s-1.79-4-4-4z" />
                            <TextBlock Text="Wrap" VerticalAlignment="Center" />
                        </StackPanel>
                    </ToggleButton>
                </WrapPanel>

                <Grid Grid.Row="2"
                      ColumnDefinitions="300,6,*"
                      ColumnSpacing="8">
                    <Border Grid.Column="0"
                            x:Name="LuaEditorSectionPane"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="6"
                            IsVisible="False">
                        <Grid RowDefinitions="Auto,Auto,*"
                              RowSpacing="6">
                            <TextBlock Grid.Row="0"
                                       FontWeight="SemiBold"
                                       Text="Sections" />
                            <TextBlock Grid.Row="1"
                                       x:Name="LuaEditorSectionSummaryText"
                                       Foreground="DarkSeaGreen"
                                       Text="Structured mode" />
                            <DataGrid Grid.Row="2"
                                      x:Name="LuaEditorSectionGrid"
                                      AutoGenerateColumns="False"
                                      HierarchicalRowsEnabled="True"
                                      SelectionChanged="OnLuaEditorSectionSelectionChanged"
                                      CanUserSortColumns="False"
                                      CanUserResizeColumns="False"
                                      HeadersVisibility="None"
                                      GridLinesVisibility="None"
                                      UseLogicalScrollable="True">
                                <DataGrid.Columns>
                                    <DataGridHierarchicalColumn Header="Section"
                                                                Width="*"
                                                                Indent="8"
                                                                x:CompileBindings="False">
                                        <DataGridHierarchicalColumn.CellTemplate>
                                            <DataTemplate x:DataType="hier:HierarchicalNode">
                                                <TextBlock Text="{Binding Item.DisplayLabel}"
                                                           FontWeight="{Binding Item.DisplayFontWeight}" />
                                            </DataTemplate>
                                        </DataGridHierarchicalColumn.CellTemplate>
                                    </DataGridHierarchicalColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Column="1"
                                  Width="6"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ResizeDirection="Columns"
                                  Background="#505050" />

                    <Border Grid.Column="2"
                            BorderThickness="1"
                            BorderBrush="#909090"
                            CornerRadius="3"
                            Padding="1">
                        <ae:TextEditor x:Name="LuaSourceEditor"
                                       FontFamily="Consolas, Courier New, monospace"
                                       FontSize="16"
                                       ShowLineNumbers="True"
                                       WordWrap="False"
                                       HorizontalScrollBarVisibility="Auto"
                                       VerticalScrollBarVisibility="Auto" />
                    </Border>
                </Grid>

                <Border Grid.Row="3"
                        BorderThickness="1"
                        BorderBrush="#505050"
                        CornerRadius="3">
                    <Grid ColumnDefinitions="*,130,160,58,66,74">
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal">
                            <Border BorderThickness="0,0,1,0"
                                    BorderBrush="#505050"
                                    Padding="8,2">
                                <TextBlock x:Name="LuaEditorStatusSourceText"
                                           TextTrimming="CharacterEllipsis"
                                           Text="script.lua" />
                            </Border>
                            <Border BorderThickness="0,0,1,0"
                                    BorderBrush="#505050"
                                    Padding="8,2">
                                <TextBlock x:Name="LuaEditorStatusModeText"
                                           Text="plain" />
                            </Border>
                            <Border BorderThickness="0,0,1,0"
                                    BorderBrush="#505050"
                                    Padding="8,2">
                                <TextBlock x:Name="LuaEditorStatusSectionText"
                                           TextTrimming="CharacterEllipsis"
                                           Text="section -" />
                            </Border>
                        </StackPanel>

                        <Border Grid.Column="1"
                                BorderThickness="0,0,1,0"
                                BorderBrush="#505050"
                                Padding="8,2">
                            <TextBlock x:Name="LuaEditorStatusSelectionBytesText"
                                       Text="Sel 0 B" />
                        </Border>

                        <Border Grid.Column="2"
                                BorderThickness="0,0,1,0"
                                BorderBrush="#505050"
                                Padding="8,2">
                            <TextBlock x:Name="LuaEditorStatusCaretText"
                                       Text="Ln 1, Col 1" />
                        </Border>

                        <Border Grid.Column="3"
                                BorderThickness="0,0,1,0"
                                BorderBrush="#505050"
                                Padding="8,2">
                            <TextBlock x:Name="LuaEditorStatusInsertModeText"
                                       HorizontalAlignment="Right"
                                       Text="INS" />
                        </Border>

                        <Border Grid.Column="4"
                                BorderThickness="0,0,1,0"
                                BorderBrush="#505050"
                                Padding="8,2">
                            <TextBlock x:Name="LuaEditorStatusEolText"
                                       HorizontalAlignment="Right"
                                       Text="LF" />
                        </Border>

                        <Border Grid.Column="5"
                                Padding="8,2">
                            <TextBlock x:Name="LuaEditorStatusEncodingText"
                                       HorizontalAlignment="Right"
                                       Text="UTF-8" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                BorderThickness="1"
                CornerRadius="0"
                Padding="8,4">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                  ColumnSpacing="8">
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Foreground="DarkSeaGreen"
                           Text="{Binding DatabaseAvailabilityDisplay, StringFormat=DB: {0}}" />

                <Border Grid.Column="1"
                        Width="1"
                        Background="#505050" />

                <TextBlock Grid.Column="2"
                           VerticalAlignment="Center"
                           Foreground="DarkOrange"
                           Text="{Binding StatusMessage}"
                           PointerPressed="OnStatusMessagePointerPressed"
                           ToolTip.Tip="Click to open full blueprint import details"
                           TextTrimming="CharacterEllipsis" />

                <Border Grid.Column="3"
                        IsVisible="{Binding HasGridEntryCountStatus}"
                        Width="1"
                        Background="#505050" />

                <TextBlock Grid.Column="4"
                           IsVisible="{Binding HasGridEntryCountStatus}"
                           VerticalAlignment="Center"
                           Foreground="DarkSeaGreen"
                           Text="{Binding GridEntryCountStatus}" />

                <Border Grid.Column="5"
                        IsVisible="{Binding RepairInProgress}"
                        Width="1"
                        Background="#505050" />

                <StackPanel Grid.Column="6"
                            IsVisible="{Binding RepairInProgress}"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center"
                               Text="{Binding RepairStatusText}" />
                    <ProgressBar Width="170"
                                 Height="14"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding RepairProgressPercent}" />
                </StackPanel>

                <Border Grid.Column="7"
                        IsVisible="{Binding BlueprintImportInProgress}"
                        Width="1"
                        Background="#505050" />

                <StackPanel Grid.Column="8"
                            IsVisible="{Binding BlueprintImportInProgress}"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center"
                               Text="{Binding BlueprintImportProgressText}" />
                    <ProgressBar Width="170"
                                 Height="14"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding BlueprintImportProgressPercent}" />
                </StackPanel>

                <Border Grid.Column="9"
                        IsVisible="{Binding ExportInProgress}"
                        Width="1"
                        Background="#505050" />

                <StackPanel Grid.Column="10"
                            IsVisible="{Binding ExportInProgress}"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center"
                               Text="{Binding ExportProgressText}" />
                    <ProgressBar Width="170"
                                 Height="14"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding ExportProgressPercent}" />
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
